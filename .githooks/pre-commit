#!/bin/bash
# ==============================================================================
# pre-commit hook (서버 전용)
# ==============================================================================
# 설치 방법 (서버에서 1회 실행):
#   cd /home/root/haccp_v3/webapp
#   git config core.hooksPath .githooks
#   chmod +x .githooks/pre-commit
#
# 동작:
#   서버 디스크에서 commit 시도 시 경고 + 의도 확인.
#   hotfix 라고 명시적으로 타이핑해야 통과.
#
# 배경:
#   2026-04-22 운영 서버에서 141커밋이 GitHub push 없이 2~3개월 쌓인 사고 방지.
#   일반 코드 변경은 로컬/Claude 에서 → GitHub PR → 서버 pull 이 정상 경로.
#   서버 직접 commit 은 긴급 hotfix 에만 허용.
# ==============================================================================

# 이 훅은 운영 서버에서만 의미 있음. 다른 환경에서는 skip.
# 서버 식별: /root/haccp_v3 디렉토리 존재 여부
if [ ! -d "/root/haccp_v3" ]; then
  # 서버가 아님 → 정상 통과
  exit 0
fi

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  ⚠️  운영 서버에서 git commit 시도가 감지되었습니다"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""
echo "  이 서버는 'pull-only' 환경입니다."
echo ""
echo "  ✅ 허용 작업 (커밋 불필요):"
echo "     • SQL 데이터 수정 / 시드 / 정합성 점검"
echo "     • PM2 restart / 로그 분석"
echo "     • npm install / build / deploy"
echo ""
echo "  🚨 커밋이 필요한 코드 변경은 다음 절차로:"
echo "     1. 로컬 또는 Claude 세션에서 수정"
echo "     2. GitHub 에 PR 올림"
echo "     3. 머지 후 서버에서 git pull"
echo ""
echo "  예외 — 긴급 hotfix 인 경우:"
echo "     • 1시간 이내 GitHub PR 로 동일 변경 올릴 의무"
echo "     • 아래 프롬프트에 'hotfix' 입력하면 통과"
echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""

# TTY 없으면 (예: Genspark 자동화 중) 차단
if [ ! -t 0 ] && [ ! -t 1 ]; then
  echo "❌ TTY 없음 — 자동화 스크립트에서 commit 시도. 차단됨."
  echo "   인간 확인 없이 서버 커밋은 허용되지 않습니다."
  exit 1
fi

read -p "  계속하려면 'hotfix' 를 정확히 입력: " CONFIRM </dev/tty

if [ "$CONFIRM" != "hotfix" ]; then
  echo ""
  echo "❌ 커밋 취소됨 (입력: '${CONFIRM}')"
  exit 1
fi

# hotfix 로그 남기기
LOG_DIR="/var/log/haccp-hotfix"
mkdir -p "$LOG_DIR" 2>/dev/null || LOG_DIR="/tmp"

{
  echo "[$(date '+%Y-%m-%d %H:%M:%S %Z')] hotfix commit allowed"
  echo "  user: $(whoami)"
  echo "  branch: $(git rev-parse --abbrev-ref HEAD)"
  echo "  staged files:"
  git diff --cached --name-only | sed 's/^/    /'
} >> "$LOG_DIR/hotfix.log"

echo ""
echo "✅ hotfix 커밋 승인됨. 1시간 이내 GitHub PR 로 올려주세요."
echo "   로그: $LOG_DIR/hotfix.log"
echo ""
exit 0
