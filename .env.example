# ═══════════════════════════════════════════════════════════════
# Millio AI 환경변수 예시 파일
# ───────────────────────────────────────────────────────────────
# 사용법:
#   1. cp .env.example .env
#   2. vi .env  (실제 값 입력)
#   3. pm2 restart haccpone --update-env
# ───────────────────────────────────────────────────────────────
# ⚠️  .env 파일은 .gitignore 에 등록되어 있어 commit 되지 않음
# ═══════════════════════════════════════════════════════════════

# ── 실행 환경 ──
NODE_ENV=production
PORT=3001
TZ=Asia/Seoul

# ── 데이터베이스 (필수) ──
# MySQL 비밀번호에 특수문자가 있으면 URL encoding 필요 (# → %23, @ → %40 등)
DATABASE_URL=mysql://root:YOUR_PASSWORD@127.0.0.1:3306/haccp_tenant_db?charset=utf8mb4
OPSCORE_DATABASE_URL=mysql://root:YOUR_PASSWORD@127.0.0.1:3306/opscore_db?charset=utf8mb4

# ── AI 챗봇 '하나' (필수 — OpenAI) ──
# https://platform.openai.com/api-keys 에서 발급
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini

# ── 이메일 발송 (선택 — SendGrid) ──
# 사용하지 않으면 빈 값 유지
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=noreply@millioai.com

# ── 세션 / 보안 (필수) ──
# 32자 이상 랜덤 문자열 권장
# 생성: openssl rand -base64 48
SESSION_SECRET=YOUR_RANDOM_SESSION_SECRET_AT_LEAST_32_CHARS

# ── CORS (도메인 제한) ──
# 쉼표 구분으로 여러 도메인 등록 가능
CORS_ORIGINS=https://millioai.com,https://v2.millioai.com

# ── GitHub Actions 자동화 (선택) ──
# 생성: openssl rand -hex 32
# 1) 백업 헬스체크 (매일 08:00 KST) — GET /api/system/backup-health
BACKUP_HEALTH_TOKEN=
# 2) 자동 배포 (Release 생성 or Actions 수동 실행) — POST /api/system/deploy
DEPLOY_TOKEN=

# ── FSSC 22000 / 글로벌 기능 (향후) ──
# FSSC_SCHEME_VERSION=v6
# DEFAULT_LANGUAGE=ko
